# ── AccelByte Credentials (required) ────────────────────────────────────
AB_BASE_URL=
AB_CLIENT_ID=
AB_CLIENT_SECRET=
AB_NAMESPACE=

# ── Extend Public URL (required for webhook callback construction) ────────────
# Automatically be assigned using AB_BASE_URL when your Extend app is provisioned on AccelByte.
# For local dev, use localhost or your ngrok URL if testing real provider webhooks
PUBLIC_BASE_URL=

# ── Auth (false = skip AGS token validation for local development) ────────────
PLUGIN_GRPC_SERVER_AUTH_ENABLED=true

# ── REST Gateway Base Path ───────────────────────────────────────────────────
BASE_PATH=/payment

# ── Extend NoSQL Database (auto-injected by Extend platform in production) ───
# Empty DOCDB_HOST = connect to localhost:27017 (no TLS) for local dev
DOCDB_HOST=
DOCDB_USERNAME=
DOCDB_PASSWORD=
DOCDB_CA_CERT_FILE_PATH=
DOCDB_DATABASE_NAME=payment

# ── Tuning ───────────────────────────────────────────────────────────────────
PAYMENT_EXPIRY_DEFAULT=15m          # How long a newly-created payment transaction stays payable before it expires.
RECORD_RETENTION_DAYS=90            # How long completed transaction records are retained before scheduled deletion.
MAX_CONCURRENT_INTENT_PER_USER=5    # Maximum number of active pending payment intents allowed per user.
WEBHOOK_MAX_AGE=5m                  # Maximum accepted age for provider webhook timestamps, when timestamp validation is configured.
MAX_RETRIES=3                       # Maximum retry count used by background recovery/scheduler flows.
LOG_LEVEL=info                      # Application log verbosity, for example debug, info, warn, or error.
WEBHOOK_FORCE_ERROR=false           # Simulate webhook error for testing
PUBLIC_SYNC_COOLDOWN=60s            # Minimum time before the same user can trigger another public sync for the same provider/scope.
PUBLIC_SYNC_DEFAULT_PAGE_SIZE=10    # Number of the user's transactions synced per request when pageSize is not provided.
PUBLIC_SYNC_MAX_PAGE_SIZE=20        # Hard cap for public sync pageSize to prevent large client-triggered provider scans.

# ── Testing ───────────────────────────────────────────────────────────────────
WEBHOOK_FORCE_ERROR=false # Simulate webhook error for testing

# ── Ports (defaults match AccelByte Extend Service Extension template) ────────
# GRPC_PORT=6565
# HTTP_PORT=8000
# METRICS_PORT=8080

# ── Xendit Hosted Checkout Adapter (optional) ────────────────────────────────
# Enables first-class provider "xendit". Use with PROVIDER_CUSTOM +
# customProviderName="xendit". Webhook URL in Xendit dashboard:
# {PUBLIC_BASE_URL}{BASE_PATH}/v1/webhook/xendit
XENDIT_SECRET_API_KEY=
XENDIT_CALLBACK_TOKEN=
XENDIT_API_BASE_URL=https://api.xendit.co
XENDIT_DEFAULT_COUNTRY=ID
XENDIT_ALLOWED_COUNTRIES=ID,PH,VN,TH,SG,MY,HK,MX
XENDIT_ALLOWED_CURRENCIES=IDR,PHP,VND,THB,SGD,MYR,USD,HKD,AUD,GBP,EUR,JPY,MXN
# Optional checkout display allowlist. Empty means Xendit is shown for all checkout regions.
# Use comma-separated AGS region/country codes, for example ID,PH,SG.
REGION_ALLOWLIST_PROVIDER_XENDIT=

# ── KOMOJU Hosted Page Adapter (optional) ───────────────────────────────────
# Enables first-class provider "komoju". Use with PROVIDER_KOMOJU.
# Webhook URL in KOMOJU dashboard:
# {PUBLIC_BASE_URL}{BASE_PATH}/v1/webhook/komoju
KOMOJU_SECRET_KEY=
KOMOJU_WEBHOOK_SECRET=
KOMOJU_API_VERSION=2025-01-28
KOMOJU_DEFAULT_LOCALE=en
KOMOJU_ALLOWED_CURRENCIES=JPY,USD,EUR,TWD,KRW,PLN,GBP,HKD,SGD,NZD,AUD,IDR,MYR,PHP,THB,CNY,BRL,CHF,CAD,VND
# Optional checkout display allowlist. Empty means KOMOJU is shown for all checkout regions.
# Use comma-separated AGS region/country codes, for example JP,US,SG.
REGION_ALLOWLIST_PROVIDER_KOMOJU=

# Optional checkout display allowlist for any provider.
# Format: REGION_ALLOWLIST_PROVIDER_{NAME}= where NAME is the provider ID without provider_, uppercased.
# Example provider ID provider_my_gateway uses REGION_ALLOWLIST_PROVIDER_MY_GATEWAY=

# Optional Generic provider cancellation support.
# GENERIC_{NAME}_CANCEL_URL_TEMPLATE=
# GENERIC_{NAME}_CANCEL_METHOD=POST
# GENERIC_{NAME}_CANCEL_BODY_TEMPLATE=
# GENERIC_{NAME}_CANCEL_STATUS_PATH=
# GENERIC_{NAME}_CANCEL_SUCCESS_VALUES=
# GENERIC_{NAME}_CANCEL_EXPIRED_VALUES=
# GENERIC_{NAME}_CANCEL_PAID_VALUES=
# GENERIC_{NAME}_CANCEL_PENDING_VALUES=
